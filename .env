# Firebase Yapılandırması
# Firebase Console > Project Settings > Your apps > Web app'den alınır
VITE_FIREBASE_API_KEY=YOUR_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID

# Personel giriş şifresi (Reader)
VITE_READER_PASSWORD=arte2024

# Admin olarak izin verilen e-posta adresleri (virgülle ayır)
VITE_ADMIN_EMAILS=admin@arte.com.tr,editor@arte.com.tr
